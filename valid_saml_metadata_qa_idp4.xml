<?xml version="1.0" encoding="UTF-8"?>
<md:EntityDescriptor
    xmlns:md="urn:oasis:names:tc:SAML:2.0:metadata"
    xmlns:mdui="urn:oasis:names:tc:SAML:metadata:ui"
    xmlns:shibmd="urn:mace:shibboleth:metadata:1.0"
    xmlns:ds="http://www.w3.org/2000/09/xmldsig#"
    entityID="https://shib.qa-idp4.testorg.com/idp/shibboleth">

    <md:IDPSSODescriptor protocolSupportEnumeration="urn:oasis:names:tc:SAML:2.0:protocol">

        <md:Extensions>
            <shibmd:Scope regexp="false">qa-idp4.testorg.com</shibmd:Scope>

            <mdui:UIInfo>
                <mdui:DisplayName xml:lang="en">QA Test IdP 4</mdui:DisplayName>
                <mdui:Description xml:lang="en">
                    QA SAML Identity Provider for testing purposes
                </mdui:Description>
                <mdui:Logo xml:lang="en" width="80" height="80">
                    https://shib.qa-idp4.testorg.com/logo.png
                </mdui:Logo>
            </mdui:UIInfo>
        </md:Extensions>

        <md:KeyDescriptor use="signing">
            <ds:KeyInfo>
                <ds:X509Data>
                    <ds:X509Certificate>

                    </ds:X509Certificate>
                </ds:X509Data>
            </ds:KeyInfo>
        </md:KeyDescriptor>

        <md:SingleSignOnService
            Binding="urn:oasis:names:tc:SAML:2.0:bindings:HTTP-Redirect"
            Location="https://shib.qa-idp4.testorg.com/idp/profile/SAML2/Redirect/SSO"/>

        <md:SingleSignOnService
            Binding="urn:oasis:names:tc:SAML:2.0:bindings:HTTP-POST"
            Location="https://shib.qa-idp4.testorg.com/idp/profile/SAML2/POST/SSO"/>

    </md:IDPSSODescriptor>

</md:EntityDescriptor>
